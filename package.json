{
  "name": "@ebarahona/loopback-connector-mongodb",
  "version": "1.0.0",
  "description": "Full-featured MongoDB connector for LoopBack 4 on driver 7.x. Aggregation, Change Streams, Time Series, GridFS, transactions, tailable cursors, bulk ops, and an injectable MongoService.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration",
    "test:dev": "vitest",
    "commitlint": "commitlint --edit",
    "prepare": "sh scripts/install-hooks.sh",
    "prepublishOnly": "npm run clean && npm run build",
    "leak-detection": "node --expose-gc scripts/leak-detection.mjs",
    "bench": "node bench/index.mjs",
    "docs": "typedoc"
  },
  "keywords": [
    "loopback",
    "loopback4",
    "mongodb",
    "native-driver",
    "aggregation",
    "change-streams",
    "time-series",
    "gridfs",
    "transactions",
    "loopback4 extension",
    "extension"
  ],
  "author": "Ed Barahona (https://github.com/ebarahona)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebarahona/loopback-connector-mongodb.git"
  },
  "bugs": {
    "url": "https://github.com/ebarahona/loopback-connector-mongodb/issues"
  },
  "homepage": "https://github.com/ebarahona/loopback-connector-mongodb#readme",
  "peerDependencies": {
    "@ebarahona/loopback-transport-core": ">=1.2.0 <2.0.0",
    "@loopback/core": ">=7.0.0 <8.0.0",
    "@loopback/repository": ">=8.0.0 <9.0.0"
  },
  "peerDependenciesMeta": {
    "@ebarahona/loopback-transport-core": {
      "optional": true
    }
  },
  "dependencies": {
    "debug": "^4.3.4",
    "mongodb": "^7.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@ebarahona/loopback-transport-core": "^1.2.0",
    "@loopback/core": "^7.0.12",
    "@loopback/repository": "^8.0.12",
    "@size-limit/preset-small-lib": "^11.0.0",
    "@types/debug": "^4.1.12",
    "@types/node": "^25.7.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-tsdoc": "^0.5.2",
    "lefthook": "^2.1.6",
    "mongodb-memory-server": "^11.1.0",
    "prettier": "^3.2.0",
    "rimraf": "^6.0.1",
    "size-limit": "^11.0.0",
    "tinybench": "^3.1.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "yaml": "^2.9.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "size-limit": [
    {
      "name": "dist (CommonJS)",
      "path": "dist/index.js",
      "limit": "100 KB",
      "ignore": [
        "@loopback/core",
        "@loopback/repository",
        "mongodb",
        "debug"
      ]
    }
  ],
  "type": "commonjs"
}
