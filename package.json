{
  "name": "@ebarahona/loopback-connector-mongodb",
  "version": "1.0.0",
  "description": "Native MongoDB service for LoopBack 4. Full driver access: aggregation, Change Streams, Time Series, GridFS, transactions, tailable cursors, and CRUD.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration",
    "test:dev": "vitest",
    "prepublishOnly": "npm run clean && npm run lint && npm run build && npm test"
  },
  "keywords": [
    "loopback",
    "loopback4",
    "mongodb",
    "native-driver",
    "aggregation",
    "change-streams",
    "time-series",
    "gridfs",
    "transactions",
    "loopback4 extension",
    "extension"
  ],
  "author": "Ed Barahona (https://github.com/ebarahona)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebarahona/loopback-service-mongodb.git"
  },
  "bugs": {
    "url": "https://github.com/ebarahona/loopback-service-mongodb/issues"
  },
  "homepage": "https://github.com/ebarahona/loopback-service-mongodb#readme",
  "peerDependencies": {
    "@loopback/core": ">=7.0.0 <8.0.0",
    "@loopback/repository": ">=8.0.0 <9.0.0"
  },
  "dependencies": {
    "debug": "^4.3.4",
    "mongodb": "^6.0.0"
  },
  "devDependencies": {
    "@loopback/core": "^7.0.12",
    "@loopback/repository": "^8.0.12",
    "@types/debug": "^4.1.12",
    "@types/node": "^25.7.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.3.0",
    "mongodb-memory-server": "^10.0.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "typescript": "~5.2.2",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
